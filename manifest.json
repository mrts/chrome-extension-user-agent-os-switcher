{
  "manifest_version": 3,
  "name": "User agent OS switcher",
  "description": "Changes OS-related request headers while preserving the running Chrome version.",
  "version": "0.1.0",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "User agent OS switcher",
    "default_popup": "popup/popup.html"
  }
}
